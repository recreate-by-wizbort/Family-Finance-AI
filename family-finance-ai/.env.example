# OpenRouter (NVIDIA Nemotron и др.) — если задан только он и нет Gemini, чат идёт через OpenRouter
VITE_OPENROUTER_API_KEY=sk-or-REPLACE_WITH_YOUR_KEY
# Дубли из .env с суффиксом _1 подхватываются в vite.config.js
# VITE_OPENROUTER_API_KEY_1=

# Google Gemini (текст): https://ai.google.dev/gemini-api/docs/quickstart
# Можно задать VITE_GEMINI_API_KEY или Google_Gemini_API_KEY_1 (см. vite.config.js)
# ID модели (необязательно): по умолчанию gemini-2.5-flash
# VITE_GEMINI_MODEL=gemini-2.5-flash
# VITE_GEMINI_API_KEY=
# Google_Gemini_API_KEY_1=

# Явный выбор: gemini | openrouter (если не задан — при наличии ключа Gemini используется он)
# VITE_AI_PROVIDER=gemini
